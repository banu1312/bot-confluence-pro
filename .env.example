# Bitget Futures API credentials
# Generate at: https://www.bitget.com/account/newapi
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Risk / sizing
# USDT margin allocated per trade (per position)
MARGIN_PER_TRADE=

# Dynamic position sizing (overrides MARGIN_PER_TRADE when set)
# Percentage of equity to risk per trade (default 1%)
RISK_PER_TRADE_PCT=1
# ATR period for volatility calculation (default 14)
ATR_PERIOD=14
# Multiplier for SL distance in ATR units (default 2)
ATR_MULTIPLIER_SL=2

# Trailing stop after TP1 (percentage of current price, default 0.5%)
TRAIL_PCT=0.005
