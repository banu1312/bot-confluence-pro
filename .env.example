# Bitget Futures API credentials
# Generate at: https://www.bitget.com/account/newapi
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Risk / sizing
# USDT margin allocated per trade (per position)
MARGIN_PER_TRADE=

# Dynamic position sizing (overrides MARGIN_PER_TRADE when set)
# Percentage of equity to risk per trade (default 1%)
RISK_PER_TRADE_PCT=1
# ATR period for volatility calculation (default 14)
ATR_PERIOD=14
# Multiplier for SL distance in ATR units (default 2)
ATR_MULTIPLIER_SL=2

# Trailing stop after TP1 (percentage of current price, default 0.5%)
TRAIL_PCT=0.005

# Multi-timeframe FVG validation (default true)
# Set to false to disable MTF FVG check (uses single-timeframe detection)
REQUIRE_MTF_FVG=true

# SMC Configuration overrides (default values shown)
# Set to false to disable individual gates
REQUIRE_STRUCTURE_BIAS=true
REQUIRE_4H_BIAS=true
REQUIRE_UNMITIGATED=true
REQUIRE_LIQUIDITY_SWEEP=true
REQUIRE_DISPLACEMENT=true
REQUIRE_OB_CONFLUENCE=false
REQUIRE_NO_INDUCEMENT=false
KILL_ZONE_ONLY=false

# Numeric parameters
MIN_RR=3
TP_COUNT=2
SL_BUFFER_PCT=0.002
MIN_FVG_AGE=1
LTF_FVG_MAX_AGE=30
HTF_FVG_MAX_AGE=50

# Swing detection parameters
HTF_4H_SWING_LOOKBACK=5
HTF_SWING_LOOKBACK=3
LTF_SWING_LOOKBACK=2

# Liquidity sweep parameters
SWEEP_WINDOW=5
SWEEP_LOOKBACK_BARS=25

# Order block parameters
OB_LOOKBACK=5

# Inducement parameters
MIN_INDUCEMENT_BARS=2

# Displacement parameters
DISPLACEMENT_MIN_BODY=0.5
DISPLACEMENT_MIN_VOL_MULTIPLIER=1.0
